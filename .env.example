# Root Environment Variables for AsyncFlowState Monorepo
# Copy this file to .env.local and fill in your values if needed

# Development settings
NODE_ENV=development
DEBUG=false

# Workspace configuration
PNPM_LOCKFILE_ONLY=false

# Testing
VITEST_DEBUG=false
COVERAGE_THRESHOLD=80

# API endpoints
VITE_API_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Feature flags
ENABLE_EXPERIMENTAL_FEATURES=false
