# NPM Registry Configuration for AsyncFlowState

# Use pnpm as package manager
enable-pre-post-scripts=true

# Registry settings
registry=https://registry.npmjs.org/

# Public packages configuration
@asyncflowstate:registry=https://registry.npmjs.org/

# Workspace configuration
workspace-root=true

# Strict peer dependencies
strict-peer-dependencies=true

# NPM authentication (set via command line or environment)
# //registry.npmjs.org/:_authToken=${NPM_TOKEN}

# Git configuration for packages
git-publish-dry-run=false

# Build settings for packages
save-exact=false

# Allow postinstall scripts
ignore-scripts=false
