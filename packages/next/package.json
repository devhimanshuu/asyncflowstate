{
  "name": "@asyncflowstate/next",
  "version": "2.0.0",
  "private": false,
  "description": "Next.js optimized integration for AsyncFlowState. Handle SSR, server actions, and app router transitions with declarative loading states.",
  "keywords": [
    "nextjs",
    "react",
    "async",
    "state",
    "loading",
    "server-actions",
    "app-router",
    "ux",
    "typescript"
  ],
  "author": "AsyncFlowState Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/devhimanshuu/asyncflowstate.git",
    "directory": "packages/next"
  },
  "bugs": "https://github.com/devhimanshuu/asyncflowstate/issues",
  "homepage": "https://asyncflowstate-js.pages.dev/frameworks/next",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=16.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "next": "^13.4.0 || ^14.0.0 || ^15.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@asyncflowstate/core": "workspace:*",
    "@asyncflowstate/react": "workspace:*"
  },
  "devDependencies": {
    "next": "^15.1.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7"
  }
}
