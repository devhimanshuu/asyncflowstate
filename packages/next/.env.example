# Next.js Package Environment Variables
# Copy this file to .env.local or .env.local.example and fill in your values

# Debug mode
DEBUG=false
NEXT_DEBUG=false

# Environment
NODE_ENV=development

# API Configuration
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Server Action settings
NEXT_ENABLE_SERVER_ACTIONS=true

# Transition settings
NEXT_TRANSITION_DEBUG=false

# Database/API endpoints (if applicable)
DATABASE_URL=
API_SECRET=
