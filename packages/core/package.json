{
  "name": "@asyncflowstate/core",
  "version": "2.0.0",
  "private": false,
  "description": "Framework-agnostic core for AsyncFlowState. A tiny, powerful engine to orchestrate complex async UI behaviors, retries, and optimistic updates.",
  "keywords": [
    "async",
    "state",
    "flow",
    "loading",
    "error-handling",
    "retry",
    "optimistic-ui",
    "ux",
    "typescript",
    "vanilla-js",
    "state-machine",
    "fsm",
    "middleware",
    "broadcast-channel",
    "sync",
    "logic",
    "promise",
    "orchestration"
  ],
  "author": "AsyncFlowState Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/devhimanshuu/asyncflowstate.git",
    "directory": "packages/core"
  },
  "bugs": "https://github.com/devhimanshuu/asyncflowstate/issues",
  "homepage": "https://asyncflowstate-js.pages.dev/api/core",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=16.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  }
}
