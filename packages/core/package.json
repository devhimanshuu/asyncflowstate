{
  "name": "@asyncflowstate/core",
  "version": "1.0.0",
  "private": false,
  "description": "Framework-agnostic async UI behavior engine for controlling loading, success, and error states",
  "keywords": [
    "async",
    "state",
    "flow",
    "loading",
    "error-handling",
    "retry",
    "optimistic-ui",
    "ux"
  ],
  "author": "AsyncFlowState Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/asyncflowstate/asyncflowstate.git",
    "directory": "packages/core"
  },
  "bugs": "https://github.com/asyncflowstate/asyncflowstate/issues",
  "homepage": "https://github.com/asyncflowstate/asyncflowstate#readme",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=16.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  }
}
