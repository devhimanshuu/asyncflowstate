{
  "name": "@asyncflowstate/svelte",
  "version": "2.0.2",
  "private": false,
  "description": "Official Svelte bindings for AsyncFlowState. Reactive stores (createFlow, createFlowSequence, createFlowParallel) for managing async loading, error, and success states effortlessly.",
  "keywords": [
    "svelte",
    "svelte5",
    "runes",
    "stores",
    "async",
    "state",
    "loading",
    "error-handling",
    "ux",
    "typescript",
    "data-fetching",
    "state-management"
  ],
  "author": "AsyncFlowState Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/devhimanshuu/asyncflowstate.git",
    "directory": "packages/svelte"
  },
  "bugs": "https://github.com/devhimanshuu/asyncflowstate/issues",
  "homepage": "https://asyncflowstate-js.pages.dev/frameworks/svelte",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "svelte": "./dist/index.mjs",
  "exports": {
    ".": {
      "svelte": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=16.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "svelte": "^4.0.0 || ^5.0.0"
  },
  "dependencies": {
    "@asyncflowstate/core": "workspace:*"
  },
  "devDependencies": {
    "svelte": "^5.28.6"
  }
}
