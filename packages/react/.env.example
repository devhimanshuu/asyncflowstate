# React Package Environment Variables
# Copy this file to .env.local and fill in your values if needed

# Debug mode - Enable verbose logging for hooks
DEBUG=false
REACT_DEBUG=false

# Test environment
NODE_ENV=development

# API Base URL for examples
VITE_API_BASE_URL=http://localhost:3000

# Enable Flow Provider debugging
REACT_FLOW_DEBUG=false

# Notification settings
REACT_FLOW_NOTIFICATION_ENABLED=true
REACT_FLOW_NOTIFICATION_AUTO_HIDE=true
REACT_FLOW_NOTIFICATION_DURATION=3000
