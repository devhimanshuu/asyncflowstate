{
  "name": "asyncflowstate",
  "version": "3.0.0",
  "description": "The ultimate async state manager for modern UIs. Eliminate `isLoading` boilerplate in React, Vue, Svelte, Angular, Solid, Next.js, and vanilla JS with declarative flows.",
  "private": true,
  "keywords": [
    "async",
    "state",
    "flow",
    "react",
    "nextjs",
    "vue",
    "svelte",
    "angular",
    "solidjs",
    "loading",
    "error-handling",
    "ux",
    "ui",
    "typescript",
    "javascript",
    "data-fetching",
    "state-management",
    "async-await",
    "promise",
    "workflow",
    "orchestrator",
    "boilerplate-killer"
  ],
  "author": "AsyncFlowState Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/devhimanshuu/asyncflowstate.git"
  },
  "bugs": "https://github.com/devhimanshuu/asyncflowstate/issues",
  "homepage": "https://asyncflowstate-js.pages.dev/",
  "scripts": {
    "build": "pnpm -r build",
    "build:core": "pnpm --filter @asyncflowstate/core build",
    "build:react": "pnpm --filter @asyncflowstate/react build",
    "build:vue": "pnpm --filter @asyncflowstate/vue build",
    "build:svelte": "pnpm --filter @asyncflowstate/svelte build",
    "build:angular": "pnpm --filter @asyncflowstate/angular build",
    "build:solid": "pnpm --filter @asyncflowstate/solid build",
    "dev": "pnpm -r --parallel dev",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "pnpm -r exec rm -rf dist",
    "prepublishOnly": "pnpm build",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish --access public",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=16.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@eslint/js": "^9.20.0",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/node": "^25.2.0",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.29.0",
    "@typescript-eslint/parser": "^8.29.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.20.0",
    "eslint-plugin-react": "^7.37.3",
    "eslint-plugin-react-hooks": "^5.1.0",
    "jsdom": "^27.4.0",
    "postcss": "^8.5.8",
    "prettier": "^3.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^4.2.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitepress": "^1.6.4",
    "vitest": "^4.0.17",
    "vue": "^3.5.32"
  }
}
