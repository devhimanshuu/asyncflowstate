{
  "name": "asyncflowstate",
  "version": "1.0.0",
  "description": "The ultimate async state manager for modern UIs. Eliminate `isLoading` boilerplate in React, Next.js, and vanilla JS with declarative flows.",
  "private": true,
  "keywords": [
    "async",
    "state",
    "flow",
    "react",
    "nextjs",
    "loading",
    "error-handling",
    "ux",
    "ui",
    "typescript",
    "javascript",
    "data-fetching",
    "state-management",
    "async-await",
    "promise",
    "workflow",
    "orchestrator",
    "boilerplate-killer"
  ],
  "author": "AsyncFlowState Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/devhimanshuu/asyncflowstate.git"
  },
  "bugs": "https://github.com/devhimanshuu/asyncflowstate/issues",
  "homepage": "https://github.com/devhimanshuu/asyncflowstate#readme",
  "scripts": {
    "build": "pnpm -r build",
    "build:core": "pnpm --filter @asyncflowstate/core build",
    "build:react": "pnpm --filter @asyncflowstate/react build",
    "dev": "pnpm -r --parallel dev",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "pnpm -r exec rm -rf dist",
    "prepublishOnly": "pnpm build",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=16.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@eslint/js": "^9.20.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/node": "^25.2.0",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.29.0",
    "@typescript-eslint/parser": "^8.29.0",
    "eslint": "^9.20.0",
    "eslint-plugin-react": "^7.37.3",
    "eslint-plugin-react-hooks": "^5.1.0",
    "jsdom": "^27.4.0",
    "prettier": "^3.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.17"
  }
}
