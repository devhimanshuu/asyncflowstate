{
  "name": "asyncflowstate",
  "version": "1.0.0",
  "description": "Async UI behavior orchestration engine for React and Next.js",
  "private": true,
  "keywords": [
    "async",
    "state",
    "flow",
    "react",
    "nextjs",
    "loading",
    "error-handling",
    "ux",
    "ui"
  ],
  "author": "AsyncFlowState Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/asyncflowstate/asyncflowstate.git"
  },
  "bugs": "https://github.com/asyncflowstate/asyncflowstate/issues",
  "homepage": "https://github.com/asyncflowstate/asyncflowstate#readme",
  "scripts": {
    "build": "pnpm -r build",
    "build:core": "pnpm --filter @asyncflowstate/core build",
    "build:react": "pnpm --filter @asyncflowstate/react build",
    "dev": "pnpm -r --parallel dev",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc -b",
    "lint": "eslint packages/*/src/**/*.ts",
    "clean": "pnpm -r exec rm -rf dist",
    "prepublishOnly": "pnpm build"
  },
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=16.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "jsdom": "^27.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.17"
  }
}
