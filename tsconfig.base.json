{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "declaration": true,
    "outDir": "dist",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@asyncflowstate/core": ["./packages/core/src"],
      "@asyncflowstate/react": ["./packages/react/src"],
      "@asyncflowstate/next": ["./packages/next/src"],
      "@asyncflowstate/vue": ["./packages/vue/src"],
      "@asyncflowstate/svelte": ["./packages/svelte/src"],
      "@asyncflowstate/angular": ["./packages/angular/src"],
      "@asyncflowstate/solid": ["./packages/solid/src"]
    }
  }
}
